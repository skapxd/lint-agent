{
  "name": "@skapxd/eslint-opinionated",
  "version": "7.3.0",
  "description": "Reusable ESLint architectural rules for TypeScript, React, backend, frontend, and package projects",
  "packageManager": "pnpm@11.2.2",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "skapxd-lint": "./dist/cli.mjs"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/astro/index.d.mts",
        "default": "./dist/astro/index.mjs"
      },
      "require": {
        "types": "./dist/astro/index.d.ts",
        "default": "./dist/astro/index.js"
      }
    },
    "./nest": {
      "import": {
        "types": "./dist/nest/index.d.mts",
        "default": "./dist/nest/index.mjs"
      },
      "require": {
        "types": "./dist/nest/index.d.ts",
        "default": "./dist/nest/index.js"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next/index.d.mts",
        "default": "./dist/next/index.mjs"
      },
      "require": {
        "types": "./dist/next/index.d.ts",
        "default": "./dist/next/index.js"
      }
    },
    "./shared": {
      "import": {
        "types": "./dist/shared/index.d.mts",
        "default": "./dist/shared/index.mjs"
      },
      "require": {
        "types": "./dist/shared/index.d.ts",
        "default": "./dist/shared/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsup && eslint src",
    "lint:fix": "tsup && eslint src --fix",
    "lint:changed": "tsup && node dist/cli.mjs --changed",
    "measure:rules": "pnpm build && node scripts/measure-rule-timing.mjs",
    "skapxd-lint": "node dist/cli.mjs",
    "skapxd-lint:build": "pnpm build && node dist/cli.mjs",
    "test:peer-minimum": "pnpm build && node scripts/check-peer-minimum.mjs",
    "test:peer-latest": "pnpm build && node scripts/check-peer-latest.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "typescript",
    "react",
    "architecture",
    "result"
  ],
  "author": "skapxd",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@skapxd/result": "^1.0.1",
    "@toon-format/toon": "^2.3.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5",
    "typescript-eslint": ">=8.24"
  },
  "devDependencies": {
    "@types/node": "25.0.10",
    "@types/picomatch": "^4.0.3",
    "@typescript-eslint/rule-tester": "^8.60.1",
    "@typescript-eslint/utils": "8.59.4",
    "eslint": "9.39.4",
    "jiti": "^2.7.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skapxd/eslint-opinionated"
  }
}
